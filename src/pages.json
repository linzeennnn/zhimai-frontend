{
  "pages": [
    {
      "path": "pages/index/index",
      "type": "home"
    },
    {
      "path": "pages/act-detail/index",
      "type": "page"
    },
    {
      "path": "pages/article/article",
      "type": "page"
    },
    {
      "path": "pages/search-page/index",
      "type": "page"
    },
    {
      "path": "pages/self-center/index",
      "type": "page"
    },
    {
      "path": "pages/webview/webview",
      "type": "page"
    },
    {
      "path": "pages/search-page/component/infoList",
      "type": "page"
    }
  ],
  "tabBar": {
  "color": "#2c2c2c",
  "selectedColor": "#2785FF",
  "backgroundColor": "#ffffff",
  "borderStyle": "black",
  "list": [
    {
      "pagePath": "pages/index/index",
      "iconPath": "static/tabbar/info.png",
      "selectedIconPath": "static/tabbar/info-active.png",
      "text": "信息资讯"
    },
    {
      "pagePath": "pages/self-center/index",
      "iconPath": "static/tabbar/self.png",
      "selectedIconPath": "static/tabbar/self-active.png",
      "text": "个人中心"
    }
  ]
},
  "globalStyle": {
    "backgroundColor": "@bgColor",
    "backgroundColorBottom": "@bgColorBottom",
    "backgroundColorTop": "@bgColorTop",
    "backgroundTextStyle": "@bgTxtStyle",
    "navigationBarBackgroundColor": "@titleBgColor",
    "navigationBarTextStyle": "@titleTextStyle",
    "navigationBarTitleText": "Uni Creator",
    "enablePullDownRefresh": false,
    "onReachBottomDistance": 50
  },
  "easycom": {
    "autoscan": true,
    "custom": {
      "^wd-(.*)": "wot-design-uni/components/wd-$1/wd-$1.vue"
    }
  },
  "middleware": [],
  "subPackages": []
}